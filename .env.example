# Copy to `.env` and fill in. Never commit `.env`.

# Which provider adapter the kernel uses: "anthropic", "lmstudio", "openai", or "ollama".
AGENT_PROVIDER=anthropic

# Tool permission policy: "ask" (confirm writes/exec), "allow" (auto), "deny".
AGENT_TOOL_POLICY=ask

# --- Anthropic ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model used by the Anthropic provider adapter.
AGENT_MODEL=claude-opus-4-8

# --- LM Studio (OpenAI-compatible local server) ---
# Start LM Studio's local server and load a model, then set AGENT_PROVIDER=lmstudio.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# The model identifier as shown in LM Studio (or "local-model" to use whatever is loaded).
LMSTUDIO_MODEL=local-model
# LM Studio ignores this, but the OpenAI-style header needs a value.
LMSTUDIO_API_KEY=lm-studio

# --- OpenAI (hosted) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama (native local server) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Kernel HTTP/WS bind address.
KERNEL_HOST=127.0.0.1
KERNEL_PORT=8765

# Where session JSON files are written (file-based store; sessions survive restarts).
SESSION_DIR=./sessions

# Root the read-only file viewer is sandboxed to (defaults to the CWD).
WORKSPACE_DIR=.

# MCP server (`agent-mcp-server`): expose write/exec tools too (trusted clients only).
AGENT_MCP_EXPOSE_ALL=0
